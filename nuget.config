<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSourceCredentials>
		<xpf>
			<add key="Username" value="license" />
			<add key="ClearTextPassword" value="" />
		</xpf>
	</packageSourceCredentials>

	<packageSourceMapping>
		<packageSource key="nuget.org">
			<package pattern="*" />
			<package pattern="AvaloniaUI.*" />
		</packageSource>

		<packageSource key="MyGet">
			<package pattern="Asi.*" />
			<package pattern="AreaCoverageLibraries" />
			<package pattern="Flexera.*" />
		</packageSource>
		<packageSource key="xpf">
			<package pattern="Xpf*" />
			<package pattern="Xpf" />
			<package pattern="avaloniaui*" />
		</packageSource>
	</packageSourceMapping>
</configuration>
