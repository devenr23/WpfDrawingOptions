<Window x:Class="AvaloniaXpfDrawingOptions.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DrawingOptions.Shared;assembly=DrawingOptions.Shared"
        Title="Avalonia XPF Drawing Options"
        Height="450" Width="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="5">
            <Label Margin="0 0 5 0">Drawing Type:</Label>
            <ComboBox x:Name="DrawingCombo">
                <ComboBox.Items>
                    <ComboBoxItem IsSelected="True">None</ComboBoxItem>
                    <ComboBoxItem x:Name="UseDrawingVisual">Drawing Visual</ComboBoxItem>
                    <ComboBoxItem x:Name="UseDrawingCanvas">Drawing Canvas</ComboBoxItem>
                    <ComboBoxItem x:Name="UseStreamGeometry">Stream Geometry</ComboBoxItem>
                    <ComboBoxItem x:Name="UseGeometryDrawing">GeometryDrawing</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>
            <Button x:Name="RunBenchmarkButton" Margin="10,0,0,0" Click="OnRunBenchmarkClicked"
                    ToolTip="Cycles through all drawing methods. Each gets 1s warmup then 5s measurement.">
                Run Benchmark
            </Button>
            <TextBlock x:Name="BenchmarkStatusText" Margin="10,0,0,0" VerticalAlignment="Center" FontStyle="Italic" />
        </StackPanel>

        <shared:MyDrawingVisual Grid.Row="1" x:Name="DrawingVisualElement" Visibility="{Binding IsSelected, ElementName=UseDrawingVisual, Converter={StaticResource BoolToVis}}" />
        <shared:MyCanvas Grid.Row="1" x:Name="DrawingCanvasElement" Visibility="{Binding IsSelected, ElementName=UseDrawingCanvas, Converter={StaticResource BoolToVis}}" />
        <shared:MyStreamGeometry Grid.Row="1" x:Name="StreamGeometryElement" Visibility="{Binding IsSelected, ElementName=UseStreamGeometry, Converter={StaticResource BoolToVis}}" />
        <shared:MyGeometryDrawing Grid.Row="1" x:Name="GeometryDrawingElement" Visibility="{Binding IsSelected, ElementName=UseGeometryDrawing, Converter={StaticResource BoolToVis}}" />

        <TextBlock
            Grid.Row="2"
            Text="{Binding FrameRateMonitor.RateInfo}"
            FontSize="16"
            Foreground="Black" />

        <Grid Grid.Row="3" x:Name="BenchmarkResultsBorder" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" HorizontalAlignment="Right" Margin="5,2,5,2" Click="OnCopyResultsClicked">Copy</Button>
            <Border Grid.Row="1"
                    Margin="5,0,5,5" Padding="8,6"
                    Background="#F0F0F0" CornerRadius="4">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <TextBox x:Name="BenchmarkResultsText" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="13" Foreground="#1A1A1A"
                             BorderThickness="0" Background="Transparent"
                             TextWrapping="NoWrap" IsTabStop="False" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
