<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaDrawingOptions.ViewModels"
        xmlns:local="using:AvaloniaDrawingOptions"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaDrawingOptions.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AvaloniaDrawingOptions">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="5">
            <Button Command="{Binding RunBenchmarkCommand}"
                    IsEnabled="{Binding IsRunBenchmarkEnabled}"
                    ToolTip.Tip="Measures Drawing Canvas performance: 1s warmup then 5s measurement.">
                Run Benchmark
            </Button>
            <TextBlock x:Name="BenchmarkStatusText"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       FontStyle="Italic" />
        </StackPanel>

        <local:DrawContext Grid.Row="1" x:Name="DrawContextElement" />

        <TextBlock
            Grid.Row="2"
            Text="{Binding FrameRateMonitor.RateInfo}"
            FontSize="16"
            Margin="5,0" />

        <Grid Grid.Row="3" IsVisible="{Binding IsBenchmarkResultsVisible}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0"
                    HorizontalAlignment="Right"
                    Margin="5,2,5,2"
                    Click="OnCopyResultsClicked">Copy</Button>
            <Border Grid.Row="1"
                    Margin="5,0,5,5" Padding="8,6"
                    Background="#F0F0F0" CornerRadius="4">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <SelectableTextBlock x:Name="BenchmarkResultsText"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Foreground="#1A1A1A"
                                         TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>

</Window>
