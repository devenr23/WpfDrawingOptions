<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Platforms>x64</Platforms>
		<UseWPF>true</UseWPF>
	</PropertyGroup>

	<ItemGroup>
		<None Remove="html\drawsample.js" />
		<None Remove="html\index.html" />
		<None Remove="html\pixi.html" />
		<None Remove="html\pixi.min.js" />
		<None Remove="html\webgl.html" />
	</ItemGroup>
	
	<ItemGroup>
	  <Content Include="html\drawsample.js">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </Content>
	  <Content Include="html\index.html">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </Content>
	  <Content Include="html\pixi.html">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </Content>
	  <Content Include="html\pixi.min.js">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </Content>
	  <Content Include="html\webgl.html">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </Content>
	</ItemGroup>
	
	<ItemGroup>
	  <ProjectReference Include="..\Common.Shared\Common.Shared.csproj" />
	</ItemGroup>

</Project>
